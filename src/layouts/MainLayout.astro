---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = "/images/og-cover.svg" } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#0f172a" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Saltar al contenido</a>
    <slot />
  </body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap');

  :root {
    --bg: #f8fafc;
    --surface: #ffffff;
    --surface-elevated: #ffffff;
    --surface-muted: #f1f5f9;
    --text: #334155;
    --text-soft: #64748b;
    --heading: #0f172a;
    --border: #e2e8f0;
    --accent: #059669;
    --accent-strong: #047857;
    --accent-soft: rgba(5, 150, 105, 0.08);
    --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.06);
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.07), 0 2px 4px -2px rgba(0, 0, 0, 0.04);
    --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.08), 0 4px 6px -4px rgba(0, 0, 0, 0.04);
    --shadow-card: 0 4px 12px rgba(0, 0, 0, 0.06);
    --radius-lg: 20px;
    --radius-md: 14px;
    --radius-sm: 10px;
    --container: 1100px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    color: var(--text);
    background:
      radial-gradient(ellipse at top left, rgba(5, 150, 105, 0.06), transparent 50%),
      radial-gradient(ellipse at top right, rgba(5, 150, 105, 0.04), transparent 40%),
      linear-gradient(180deg, #f8fafc 0%, #f1f5f9 60%, #e2e8f0 100%);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    line-height: 1.7;
  }

a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  img {
    display: block;
    max-width: 100%;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  :focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 3px;
  }

.skip-link {
    position: absolute;
    left: 1rem;
    top: -4rem;
    z-index: 1000;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    color: #fff;
    background: var(--heading);
    transition: top 0.2s ease;
  }

  .skip-link:focus {
    top: 1rem;
  }

  .page-shell {
    width: min(calc(100% - 2rem), var(--container));
    margin: 0 auto;
    padding: 1.5rem 0 5rem;
  }

  .section {
    position: relative;
    margin-top: 2rem;
    padding: 1.75rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow-card);
  }

  .section-header {
    display: grid;
    gap: 0.6rem;
    margin-bottom: 1.75rem;
  }

  .eyebrow {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .section-title {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    font-size: clamp(1.5rem, 2vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--heading);
  }

  .section-intro {
    max-width: 65ch;
    margin: 0;
    color: var(--text-soft);
    font-size: 1.02rem;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.9rem;
    border: 1px solid rgba(5, 150, 105, 0.15);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--accent-strong);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .tag-list,
  .bullet-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .bullet-list {
    display: grid;
    gap: 0.85rem;
  }

  .bullet-list li {
    position: relative;
    padding-left: 1.1rem;
    color: var(--text-soft);
  }

.bullet-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.65rem;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--accent);
  }

  @media (min-width: 768px) {
    .page-shell {
      width: min(calc(100% - 3rem), var(--container));
      padding-top: 2rem;
      padding-bottom: 6rem;
    }

    .section {
      margin-top: 2.5rem;
      padding: 2.25rem;
    }
  }

  @media (min-width: 1024px) {
    .section {
      padding: 2.75rem;
    }
  }
</style>
