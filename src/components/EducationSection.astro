---
import SectionHeading from "./SectionHeading.astro";

interface EducationItem {
  degree: string;
  institution: string;
  period: string;
  details: string[];
}

interface Props {
  items: EducationItem[];
}

const { items } = Astro.props;
---

<section class="section">
  <SectionHeading
    eyebrow="Formación académica"
    title="Base académica alineada con operación e infraestructura"
  />

  <div class="cards-grid">
    {items.map((item) => (
      <article class="info-card">
        <div class="info-card-top">
          <h3>{item.degree}</h3>
          <p>{item.period || "Completar fechas"}</p>
        </div>
        <p class="institution">{item.institution || "Completar institucion"}</p>

        {item.details.length > 0 && (
          <details class="edu-details">
            <summary class="edu-details-summary">
              <span>{item.details.length} detalles</span>
              <span class="toggle-icon" aria-hidden="true"></span>
            </summary>
            <ul class="bullet-list">
              {item.details.map((detail) => (
                <li>{detail}</li>
              ))}
            </ul>
          </details>
        )}
      </article>
    ))}
  </div>
</section>

<style>
  .cards-grid {
    display: grid;
    gap: 1rem;
  }

  .info-card {
    padding: 1.25rem;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-xs);
    transition: transform 0.2s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .info-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glass);
    border-color: var(--accent-subtle);
  }

  .info-card-top {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.625rem;
  }

  h3,
  .info-card-top p,
  .institution {
    margin: 0;
  }

  h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--heading);
    line-height: 1.3;
  }

  .info-card-top p {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--accent-dark);
    background: var(--accent-light);
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .institution {
    margin-bottom: 0.875rem;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--text-secondary);
  }

  /* Accordion */
  .edu-details {
    border-top: 1px solid var(--border-light);
    padding-top: 0.625rem;
  }

  .edu-details-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    cursor: pointer;
    list-style: none;
    padding: 0.2rem 0;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--accent-dark);
    user-select: none;
  }

  .edu-details-summary::-webkit-details-marker {
    display: none;
  }

  .toggle-icon {
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 999px;
    background: var(--accent-light);
    flex-shrink: 0;
    position: relative;
    transition: background 0.2s ease, transform 0.25s ease;
  }

  .toggle-icon::before,
  .toggle-icon::after {
    content: "";
    position: absolute;
    background: var(--accent-dark);
    border-radius: 2px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .toggle-icon::before {
    width: 8px;
    height: 2px;
  }

  .toggle-icon::after {
    width: 2px;
    height: 8px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }

  details[open] .toggle-icon {
    background: var(--accent);
    transform: rotate(45deg);
  }

  details[open] .toggle-icon::before,
  details[open] .toggle-icon::after {
    background: #fff;
  }

  .edu-details .bullet-list {
    margin-top: 0.625rem;
    display: grid;
    gap: 0.375rem;
  }

  .edu-details .bullet-list li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .edu-details .bullet-list li::before {
    content: "·";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  @media (min-width: 768px) {
    .info-card {
      padding: 1.5rem;
    }

    .cards-grid {
      gap: 1.125rem;
    }
  }
</style>
