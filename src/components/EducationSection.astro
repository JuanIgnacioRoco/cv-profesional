---
import SectionHeading from "./SectionHeading.astro";

interface EducationItem {
  degree: string;
  institution: string;
  period: string;
  details: string[];
}

interface Props {
  items: EducationItem[];
}

const { items } = Astro.props;
---

<section class="section">
  <SectionHeading
    eyebrow="Formacion academica"
    title="Base academica alineada con operacion e infraestructura"
    intro="Presentacion compacta para destacar estudios formales y dejar listos los campos que puedan completarse con mas detalle mas adelante."
  />

  <div class="cards-grid">
    {items.map((item) => (
      <article class="info-card">
        <div class="info-card-top">
          <h3>{item.degree}</h3>
          <p>{item.period || "Completar fechas"}</p>
        </div>
        <p class="institution">{item.institution || "Completar institucion"}</p>
        <ul class="bullet-list">
          {item.details.map((detail) => (
            <li>{detail}</li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>

<style>
  .cards-grid {
    display: grid;
    gap: 1rem;
  }

  .info-card {
    padding: 1.25rem;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-xs);
    transition: transform 0.2s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .info-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glass);
    border-color: var(--accent-subtle);
  }

  .info-card-top {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.625rem;
  }

  h3,
  .info-card-top p,
  .institution {
    margin: 0;
  }

  h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--heading);
    line-height: 1.3;
  }

  .info-card-top p {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--accent-dark);
    background: var(--accent-light);
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .info-card-top p,
  .institution {
    color: var(--text-secondary);
  }

  .institution {
    margin-bottom: 0.875rem;
    font-weight: 600;
    font-size: 0.9375rem;
  }

  @media (min-width: 768px) {
    .info-card {
      padding: 1.5rem;
    }

    .cards-grid {
      gap: 1.125rem;
    }
  }
</style>
