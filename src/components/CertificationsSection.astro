---
import SectionHeading from "./SectionHeading.astro";

interface CertificationItem {
  name: string;
  issuer: string;
  year: string;
}

interface Props {
  items: CertificationItem[];
}

const { items } = Astro.props;
---

<section class="section">
  <SectionHeading
    eyebrow="Certificaciones y especializaciones"
    title="Credenciales que refuerzan experiencia tecnica y criterio operativo"
    intro="Presentacion sobria para facilitar lectura rapida y validacion de especializacion por parte de reclutadores."
  />

  <ul class="cert-grid tag-list">
    {items.map((item) => (
      <li class="cert-card">
        <strong>{item.name}</strong>
        <span>{[item.issuer, item.year].filter(Boolean).join(" | ") || "Completar emisor o ano"}</span>
      </li>
    ))}
  </ul>
</section>

<style>
  .cert-grid {
    display: grid;
    gap: 0.875rem;
  }

  .cert-card {
    display: grid;
    gap: 0.375rem;
    padding: 1.125rem 1.25rem;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-xs);
    transition: transform 0.2s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .cert-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glass);
    border-color: var(--accent-subtle);
  }

  .cert-card strong {
    color: var(--heading);
    font-size: 0.9375rem;
    font-weight: 600;
  }

  .cert-card span {
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  @media (min-width: 768px) {
    .cert-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
  }
</style>
