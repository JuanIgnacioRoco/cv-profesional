---
import SectionHeading from "./SectionHeading.astro";

interface CertificationItem {
  name: string;
  issuer: string;
  year: string;
}

interface Props {
  items: CertificationItem[];
}

const { items } = Astro.props;
---

<section class="section">
  <SectionHeading
    eyebrow="Certificaciones y especializaciones"
    title="Credenciales que refuerzan experiencia tecnica y criterio operativo"
    intro="Presentacion sobria para facilitar lectura rapida y validacion de especializacion por parte de reclutadores."
  />

  <ul class="cert-grid tag-list">
    {items.map((item) => (
      <li class="cert-card">
        <strong>{item.name}</strong>
        <span>{[item.issuer, item.year].filter(Boolean).join(" | ") || "Completar emisor o ano"}</span>
      </li>
    ))}
  </ul>
</section>

<style>
  .cert-grid {
    display: grid;
    gap: 1rem;
  }

  .cert-card {
    display: grid;
    gap: 0.4rem;
    padding: 1.25rem 1.35rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .cert-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
  }

  .cert-card strong {
    color: var(--heading);
    font-size: 1rem;
  }

  .cert-card span {
    color: var(--text-soft);
    font-size: 0.92rem;
  }

  @media (min-width: 768px) {
    .cert-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
