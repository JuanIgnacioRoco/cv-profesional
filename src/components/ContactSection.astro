---
import SectionHeading from "./SectionHeading.astro";

interface Props {
  contact: {
    email: string;
    linkedin: string;
    whatsapp: string;
    cta: string;
  };
}

const { contact } = Astro.props;
---

<section class="section contact-section">
  <SectionHeading
    eyebrow="Contacto rapido"
    title="Canales directos para avanzar una conversacion profesional"
    intro={contact.cta}
  />

  <div class="contact-actions">
    <a class="contact-link" href={`mailto:${contact.email}`}>
      <span class="contact-label">Email</span>
      <strong>{contact.email}</strong>
    </a>
    <a class="contact-link" href={contact.linkedin} target="_blank" rel="noreferrer">
      <span class="contact-label">LinkedIn</span>
      <strong>Ver perfil profesional</strong>
    </a>
    <a class="contact-link" href={contact.whatsapp} target="_blank" rel="noreferrer">
      <span class="contact-label">WhatsApp</span>
      <strong>Iniciar contacto</strong>
    </a>
  </div>
</section>

<style>
  .contact-section {
    overflow: hidden;
  }

  .contact-section::after {
    content: "";
    position: absolute;
    right: -4rem;
    bottom: -4rem;
    width: 14rem;
    height: 14rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(5, 150, 105, 0.1), transparent 70%);
    pointer-events: none;
  }

  .contact-actions {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1rem;
  }

  .contact-link {
    display: grid;
    gap: 0.3rem;
    padding: 1.25rem 1.35rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .contact-link:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
  }

  .contact-label {
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-link strong {
    color: var(--heading);
    font-size: 1rem;
  }

  @media (min-width: 768px) {
    .contact-actions {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
