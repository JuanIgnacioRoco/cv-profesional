---
interface Props {
  profile: {
    fullName: string;
    headline: string;
    valueProposition: string;
    photo: {
      src: string;
      alt: string;
    };
    highlights: string[];
  };
  contact: {
    email: string;
    linkedin: string;
    whatsapp: string;
    location?: string;
  };
}

const { profile, contact } = Astro.props;
---

<section class="hero section">
  <div class="hero-copy">
    <p class="eyebrow">Perfil profesional</p>
    <h1>{profile.fullName}</h1>
    <p class="hero-headline">{profile.headline}</p>
    <p class="hero-value">{profile.valueProposition}</p>

    <ul class="hero-highlights tag-list" aria-label="Fortalezas principales">
      {profile.highlights.map((item) => (
        <li class="pill">{item}</li>
      ))}
    </ul>

    <div class="hero-actions">
      <a class="button button-primary" href={`mailto:${contact.email}`} aria-label="Enviar email">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 6h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1zm0 2v.5l8 5 8-5V8l-8 5-8-5z" />
        </svg>
        <span>Email</span>
      </a>
      <a class="button button-secondary" href={contact.linkedin} target="_blank" rel="noreferrer" aria-label="Abrir perfil de LinkedIn">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6.5 8.5A1.5 1.5 0 1 1 6.5 5a1.5 1.5 0 0 1 0 3.5zM5 10h3v9H5v-9zm5 0h2.9v1.3h.1c.4-.8 1.4-1.6 3-1.6 3.2 0 3.8 2 3.8 4.7V19h-3v-4c0-1 0-2.3-1.5-2.3s-1.7 1.1-1.7 2.2V19h-3v-9z" />
        </svg>
        <span>LinkedIn</span>
      </a>
      <a class="button button-secondary" href={contact.whatsapp} target="_blank" rel="noreferrer" aria-label="Abrir chat de WhatsApp">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3a9 9 0 0 0-7.8 13.5L3 21l4.7-1.2A9 9 0 1 0 12 3zm0 16.2a7.2 7.2 0 0 1-3.7-1l-.3-.2-2.8.7.8-2.7-.2-.3a7.2 7.2 0 1 1 6.2 3.5zm3.9-5.4c-.2-.1-1.3-.6-1.5-.7-.2-.1-.4-.1-.6.1l-.5.7c-.1.2-.3.2-.5.1-1.4-.7-2.4-2-2.6-2.3-.1-.2 0-.3.1-.5l.4-.5c.1-.1.2-.3.3-.4.1-.1.1-.2 0-.4l-.7-1.7c-.2-.4-.4-.4-.6-.4h-.5c-.2 0-.4.1-.6.3-.6.6-.9 1.3-.9 2.1 0 .8.6 1.7.7 1.8.1.1 1.4 2.2 3.5 3 .5.2 1 .3 1.3.4.6.2 1.1.1 1.5.1.5-.1 1.3-.5 1.5-1 .2-.5.2-.9.1-1-.1-.1-.3-.1-.5-.2z" />
        </svg>
        <span>WhatsApp</span>
      </a>
    </div>

    {contact.location && <p class="hero-location">{contact.location}</p>}
  </div>

  <div class="hero-photo-card">
    <div class="hero-photo-frame">
      <img src={profile.photo.src} alt={profile.photo.alt} width="560" height="700" loading="eager" />
    </div>
    <p class="hero-photo-note">Reemplaza esta imagen desde `src/content/profile.json` o actualizando el archivo en `public/images/`.</p>
  </div>
</section>

<style>
  .hero {
    display: grid;
    gap: 2rem;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: auto -10% -30% auto;
    width: 20rem;
    height: 20rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(5, 150, 105, 0.1), transparent 70%);
    pointer-events: none;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1.25rem;
  }

  h1 {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--heading);
  }

  .hero-headline {
    margin: 0;
    max-width: 22ch;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 600;
    color: var(--accent-strong);
    line-height: 1.4;
  }

  .hero-value {
    max-width: 65ch;
    margin: 0;
    font-size: 1.05rem;
    color: var(--text-soft);
  }

  .hero-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .hero-actions {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.7rem;
    padding-top: 0.75rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 3rem;
    min-width: 3rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid transparent;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button svg {
    width: 1.1rem;
    height: 1.1rem;
    fill: currentColor;
    flex-shrink: 0;
  }

  .button span {
    white-space: nowrap;
  }

  .button-primary {
    color: #fff;
    background: var(--accent);
    box-shadow: 0 4px 12px rgba(5, 150,105, 0.25);
  }

  .button-primary:hover {
    background: var(--accent-strong);
    box-shadow: 0 6px 16px rgba(5,150,105, 0.3);
  }

  .button-secondary {
    border-color: var(--border);
    background: var(--surface);
    color: var(--heading);
  }

  .button-secondary:hover {
    border-color: var(--accent);
    background: var(--surface);
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 430px) {
    .button span {
      display: none;
    }
  }

  .hero-location {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.95rem;
  }

  .hero-photo-card {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .hero-photo-frame {
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow-lg);
  }

  .hero-photo-frame img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .hero-photo-note {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-soft);
  }

  @media (min-width: 900px) {
    .hero {
      grid-template-columns: minmax(0, 1.55fr) minmax(280px, 0.85fr);
      align-items: center;
      padding: 2.75rem;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .button {
      padding: 0.75rem 1.25rem;
    }
  }
</style>
