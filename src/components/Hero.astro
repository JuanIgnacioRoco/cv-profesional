---
interface Props {
  profile: {
    fullName: string;
    headline: string;
    valueProposition: string;
    photo: {
      src: string;
      alt: string;
    };
    highlights: string[];
  };
  contact: {
    email: string;
    linkedin: string;
    whatsapp: string;
    location?: string;
  };
}

const { profile, contact } = Astro.props;
---

<section class="hero section">
  <div class="hero-copy">
    <p class="eyebrow">Perfil profesional</p>
    <h1>{profile.fullName}</h1>
    <p class="hero-headline">{profile.headline}</p>
    <p class="hero-value">{profile.valueProposition}</p>

    <ul class="hero-highlights tag-list" aria-label="Fortalezas principales">
      {profile.highlights.map((item) => (
        <li class="pill">{item}</li>
      ))}
    </ul>

    <div class="hero-actions">
      <a class="button button-primary" href={`mailto:${contact.email}`}>Email</a>
      <a class="button button-secondary" href={contact.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
      <a class="button button-secondary" href={contact.whatsapp} target="_blank" rel="noreferrer">WhatsApp</a>
    </div>

    {contact.location && <p class="hero-location">{contact.location}</p>}
  </div>

  <div class="hero-photo-card">
    <div class="hero-photo-frame">
      <img src={profile.photo.src} alt={profile.photo.alt} width="560" height="700" loading="eager" />
    </div>
    <p class="hero-photo-note">Reemplaza esta imagen desde `src/content/profile.json` o actualizando el archivo en `public/images/`.</p>
  </div>
</section>

<style>
  .hero {
    display: grid;
    gap: 2rem;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: auto -10% -30% auto;
    width: 20rem;
    height: 20rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(5, 150, 105, 0.1), transparent 70%);
    pointer-events: none;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1.25rem;
  }

  h1 {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--heading);
  }

  .hero-headline {
    margin: 0;
    max-width: 22ch;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 600;
    color: var(--accent-strong);
    line-height: 1.4;
  }

  .hero-value {
    max-width: 65ch;
    margin: 0;
    font-size: 1.05rem;
    color: var(--text-soft);
  }

  .hero-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 0.75rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.25rem;
    padding: 0.75rem 1.25rem;
    border: 1px solid transparent;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .button:hover {
    transform: translateY(-2px);
  }

  .button-primary {
    color: #fff;
    background: var(--accent);
    box-shadow: 0 4px 12px rgba(5, 150,105, 0.25);
  }

  .button-primary:hover {
    background: var(--accent-strong);
    box-shadow: 0 6px 16px rgba(5,150,105, 0.3);
  }

  .button-secondary {
    border-color: var(--border);
    background: var(--surface);
    color: var(--heading);
  }

  .button-secondary:hover {
    border-color: var(--accent);
    background: var(--surface);
    box-shadow: var(--shadow-md);
  }

  .hero-location {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.95rem;
  }

  .hero-photo-card {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 1rem;
    align-content: start;
  }

  .hero-photo-frame {
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow-lg);
  }

  .hero-photo-frame img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .hero-photo-note {
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-soft);
  }

  @media (min-width: 900px) {
    .hero {
      grid-template-columns: minmax(0, 1.55fr) minmax(280px, 0.85fr);
      align-items: center;
      padding: 2.75rem;
    }
  }
</style>
