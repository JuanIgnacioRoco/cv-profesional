---
import SectionHeading from "./SectionHeading.astro";

interface ExperienceItem {
  role: string;
  company: string;
  location: string;
  period: string;
  summary: string;
  highlights: string[];
  featured?: boolean;
}

interface Props {
  items: ExperienceItem[];
}

const { items } = Astro.props;
---

<section class="section">
  <SectionHeading
    eyebrow="Experiencia profesional"
    title="Trayectoria orientada a operacion, monitoreo e infraestructura"
    intro="Orden cronologico inverso con foco en cargos y responsabilidades vinculadas a cloud, continuidad operativa, soporte de plataformas criticas y automatizacion."
  />

  <div class="timeline" role="list">
    {items.map((item) => (
      <article class={`timeline-item ${item.featured ? "is-featured" : ""}`} role="listitem">
        <div class="timeline-marker" aria-hidden="true"></div>
        <div class="timeline-card">
          <div class="timeline-top">
            <div>
              <h3>{item.role}</h3>
              <p class="timeline-meta">
                {[item.company, item.location].filter(Boolean).join(" | ") || "Datos editables pendientes"}
              </p>
            </div>
            <p class="timeline-period">{item.period || "Completar fechas"}</p>
          </div>

          <p class="timeline-summary">{item.summary}</p>

          <ul class="bullet-list">
            {item.highlights.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .timeline {
    position: relative;
    display: grid;
    gap: 1rem;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 0.4rem;
    top: 1rem;
    bottom: 1rem;
    width: 2px;
    background: linear-gradient(180deg, var(--accent) 0%, var(--accent-light) 100%);
  }

  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 1rem minmax(0, 1fr);
    gap: 1rem;
  }

  .timeline-marker {
    width: 0.75rem;
    height: 0.75rem;
    margin-top: 1.25rem;
    border: 2px solid var(--bg-card);
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-light);
  }

  .timeline-card {
    padding: 1.25rem;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-xs);
    transition: transform 0.2s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .timeline-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glass);
    border-color: var(--accent-subtle);
  }

  .is-featured .timeline-card {
    background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg-card-hover) 100%);
    border-color: var(--accent-subtle);
  }

  .is-featured .timeline-card:hover {
    border-color: var(--accent);
  }

  .timeline-top {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  h3 {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--heading);
  }

  .timeline-meta,
  .timeline-period,
  .timeline-summary {
    margin: 0;
    color: var(--text-secondary);
  }

  .timeline-meta {
    font-weight: 600;
    font-size: 0.9375rem;
  }

  .timeline-period {
    align-self: start;
    justify-self: start;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    background: var(--accent-light);
    color: var(--accent-dark);
    font-size: 0.8125rem;
    font-weight: 700;
  }

  .timeline-summary {
    margin-bottom: 0.875rem;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .timeline-item {
      grid-template-columns: 1.5rem minmax(0, 1fr);
      gap: 1.125rem;
    }

    .timeline::before {
      left: 0.7rem;
    }

    .timeline-card {
      padding: 1.5rem;
    }

    .timeline-top {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: start;
      gap: 0.75rem;
    }

    .timeline-period {
      justify-self: end;
    }
  }
</style>
