---
import SectionHeading from "./SectionHeading.astro";

interface ExperienceItem {
  role: string;
  company: string;
  location: string;
  period: string;
  summary: string;
  highlights: string[];
  featured?: boolean;
}

interface Props {
  items: ExperienceItem[];
}

const { items } = Astro.props;
---

<section class="section">
  <SectionHeading
    eyebrow="Experiencia profesional"
    title="Trayectoria orientada a operación, monitoreo e infraestructura"
  />

  <div class="timeline reveal-stagger" role="list">
    {items.map((item) => (
      <article class={`timeline-item ${item.featured ? "is-featured" : ""}`} role="listitem">
        <div class="timeline-marker" aria-hidden="true"></div>
        <div class="timeline-card">
          <div class="timeline-top">
            <div>
              <h3>{item.role}</h3>
              <p class="timeline-meta">
                {[item.company, item.location].filter(Boolean).join(" | ") || "Datos editables pendientes"}
              </p>
            </div>
            <p class="timeline-period">{item.period || "Completar fechas"}</p>
          </div>

          <p class="timeline-summary">{item.summary}</p>

          {item.highlights.length > 0 && (
            <details class="job-details">
              <summary class="job-details-summary">
                <span>{item.highlights.length} logros clave</span>
                <span class="toggle-icon" aria-hidden="true"></span>
              </summary>
              <ul class="bullet-list">
                {item.highlights.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </details>
          )}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .timeline {
    position: relative;
    display: grid;
    gap: 1rem;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 0.4rem;
    top: 1rem;
    bottom: 1rem;
    width: 2px;
    background: linear-gradient(180deg, var(--accent) 0%, var(--accent-light) 100%);
  }

  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 1rem minmax(0, 1fr);
    gap: 1rem;
  }

  .timeline-marker {
    width: 0.75rem;
    height: 0.75rem;
    margin-top: 1.25rem;
    border: 2px solid var(--bg-card);
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-light);
  }

  .timeline-card {
    position: relative;
    padding: 1.25rem;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-xs);
    transition: transform 0.2s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .timeline-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glass);
    border-color: var(--accent-subtle);
  }

  .is-featured .timeline-card {
    background: linear-gradient(135deg, rgba(79, 70, 229, 0.04) 0%, var(--bg-card) 100%);
    border-color: var(--accent-subtle);
    border-left: 3px solid var(--accent);
  }

  .is-featured .timeline-card:hover {
    border-color: var(--accent);
    border-left-color: var(--accent);
  }

  .is-featured .timeline-card::before {
    content: "Destacado";
    position: absolute;
    top: -1px;
    right: 1rem;
    padding: 0.2rem 0.6rem;
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
    background: var(--accent);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .timeline-top {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  h3 {
    margin: 0;
    font-family: 'Sora', sans-serif;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--heading);
  }

  .timeline-meta,
  .timeline-period,
  .timeline-summary {
    margin: 0;
    color: var(--text-secondary);
  }

  .timeline-meta {
    font-weight: 600;
    font-size: 0.9375rem;
  }

  .timeline-period {
    align-self: start;
    justify-self: start;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    background: var(--accent-light);
    color: var(--accent-dark);
    font-size: 0.8125rem;
    font-weight: 700;
  }

  .timeline-summary {
    margin-bottom: 0.875rem;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  /* Accordion */
  .job-details {
    border-top: 1px solid var(--border-light);
    padding-top: 0.75rem;
  }

  .job-details-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    cursor: pointer;
    list-style: none;
    padding: 0.25rem 0;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--accent-dark);
    user-select: none;
  }

  .job-details-summary::-webkit-details-marker {
    display: none;
  }

  .toggle-icon {
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 999px;
    background: var(--accent-light);
    flex-shrink: 0;
    position: relative;
    transition: background 0.2s ease, transform 0.25s ease;
  }

  .toggle-icon::before,
  .toggle-icon::after {
    content: "";
    position: absolute;
    background: var(--accent-dark);
    border-radius: 2px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .toggle-icon::before {
    width: 8px;
    height: 2px;
  }

  .toggle-icon::after {
    width: 2px;
    height: 8px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }

  details[open] .toggle-icon {
    background: var(--accent);
    transform: rotate(45deg);
  }

  details[open] .toggle-icon::before,
  details[open] .toggle-icon::after {
    background: #fff;
  }

  .job-details .bullet-list {
    margin-top: 0.75rem;
    display: grid;
    gap: 0.5rem;
  }

  .job-details .bullet-list li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .job-details .bullet-list li::before {
    content: "·";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  @media (max-width: 767px) {
    .timeline::before { display: none; }
    .timeline-marker { display: none; }
    .timeline { gap: 0.625rem; }
    .timeline-item { grid-template-columns: minmax(0, 1fr); gap: 0; }
    .timeline-card { padding: 0.875rem 1rem; border-left: 3px solid var(--accent-subtle); }
    .timeline-card:hover { border-left-color: var(--accent); }
    .is-featured .timeline-card { border-left: 3px solid var(--accent); }
  }

  @media (min-width: 768px) {
    .timeline-item {
      grid-template-columns: 1.5rem minmax(0, 1fr);
      gap: 1.125rem;
    }

    .timeline::before {
      left: 0.7rem;
    }

    .timeline-card {
      padding: 1.5rem;
    }

    .timeline-top {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: start;
      gap: 0.75rem;
    }

    .timeline-period {
      justify-self: end;
    }
  }
</style>
