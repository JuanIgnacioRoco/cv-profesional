---
import SectionHeading from "./SectionHeading.astro";

interface CourseItem {
  name: string;
  institution: string;
  period: string;
}

interface Props {
  items: CourseItem[];
}

const { items } = Astro.props;
---

<section class="section">
  <SectionHeading
    eyebrow="Cursos"
    title="Actualizacion focalizada en herramientas y gestion"
    intro="Bloque breve para reforzar formacion complementaria sin sobrecargar la lectura."
  />

  <div class="compact-grid">
    {items.map((item) => (
      <article class="compact-card">
        <h3>{item.name}</h3>
        <p>{[item.institution, item.period].filter(Boolean).join(" | ") || "Completar institucion o fecha"}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .compact-grid {
    display: grid;
    gap: 1rem;
  }

  .compact-card {
    padding: 1.25rem 1.35rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .compact-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  h3,
  p {
    margin: 0;
  }

  h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--heading);
  }

  p {
    margin-top: 0.5rem;
    color: var(--text-soft);
    font-size: 0.92rem;
  }

  @media (min-width: 768px) {
    .compact-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
