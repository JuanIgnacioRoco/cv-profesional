---
import SectionHeading from "./SectionHeading.astro";

interface SkillGroup {
  category: string;
  items: string[];
}

interface Props {
  items: SkillGroup[];
}

const { items } = Astro.props;
---

<section class="section">
  <SectionHeading
    eyebrow="Competencias tecnicas"
    title="Capacidades organizadas por areas clave del perfil"
    intro="Agrupacion pensada para lectura rapida por parte de equipos de seleccion tecnica, operaciones, cloud e infraestructura."
  />

  <div class="skills-grid">
    {items.map((group) => (
      <article class="skill-card">
        <h3>{group.category}</h3>
        <ul class="tag-list skill-tags">
          {group.items.map((item) => (
            <li class="skill-tag">{item}</li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    gap: 1.25rem;
  }

  .skill-card {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .skill-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .skill-card h3 {
    margin: 0 0 1rem;
    font-family: 'Poppins', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--heading);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .skill-tag {
    display: inline-flex;
    align-items: center;
    min-height: 2.4rem;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    background: var(--surface-muted);
    color: var(--heading);
    font-size: 0.88rem;
    font-weight: 600;
    transition: background-color 0.2s ease;
  }

  .skill-tag:hover {
    background: var(--accent-soft);
    color: var(--accent-strong);
  }

  @media (min-width: 768px) {
    .skills-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
