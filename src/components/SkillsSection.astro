---
import SectionHeading from "./SectionHeading.astro";

interface SkillGroup {
  category: string;
  items: string[];
}

interface Props {
  items: SkillGroup[];
}

const { items } = Astro.props;

const TECH_COLORS: Record<string, string> = {
  'AWS': '#FF9900',
  'Azure': '#0078D4',
  'GCP': '#4285F4',
  'VMware': '#607078',
  'Veeam': '#00B336',
  'SharePoint Online': '#0078D4',
  'Datadog': '#632CA6',
  'Splunk': '#E20082',
  'SolarWinds': '#F08800',
  'Nagios': '#E5171F',
  'OpManager': '#E05206',
  'PRTG': '#00A0E3',
  'Pandora FMS': '#E47B1C',
  'Windows Server': '#0078D4',
  'Linux': '#E95420',
  'Active Directory': '#0078D4',
  'Azure AD': '#0078D4',
  'Microsoft Intune': '#0078D4',
  'Exchange': '#0078D4',
  'SAP': '#0FAAFF',
  'OPNsense': '#D94F00',
  'Python': '#3776AB',
  'PowerShell': '#5391FE',
  'Bash': '#4EAA25',
  'Power BI': '#F2C811',
  'SQL Server': '#CC2927',
  'Kubernetes': '#326CE5',
};

const CATEGORY_ICONS: Record<string, string> = {
  'Cloud y virtualización': '<path d="M6.5 20q-2.28 0-3.89-1.57Q1 16.86 1 14.58q0-1.95 1.17-3.48 1.17-1.53 3.08-1.95.42-2.08 2-3.37Q8.84 4.5 11 4.5q2.55 0 4.28 1.73Q17 7.96 17 10.5v.5q1.73-.02 2.86 1.09Q21 13.2 21 14.9q0 1.66-1.18 2.88Q18.65 19 17 19l-3.5.5v-2H17q.83 0 1.41-.59Q19 16.33 19 15.5q0-.83-.59-1.42Q17.83 13.5 17 13.5h-1.5v-3q0-1.87-1.32-3.19Q12.87 6 11 6q-1.87 0-3.19 1.31Q6.5 8.63 6.5 10.5H6q-1.46 0-2.48 1.03Q2.5 12.55 2.5 14q0 1.46 1.02 2.48Q4.55 17.5 6 17.5h2V20z"/>',
  'Monitoreo y observabilidad': '<path d="M4.5 17.5 3 16l7.5-7.5 4 4 5.1-5.6 1.4 1.3-6.5 7.2-4-4ZM3 20v-2h18v2Z"/>',
  'Infraestructura y administración de sistemas': '<path d="M4 1h16a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zm0 8h16a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-4a1 1 0 0 1 1-1zm0 8h16a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1v-4a1 1 0 0 1 1-1zM7 4.5a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1zm0 8a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1zm0 8a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1z"/>',
  'Scripting y automatización': '<path d="M8 3 4 7l4 4-1.5 1.5L1 7l5.5-5.5zm8 0 5.5 5.5L16 14l-1.5-1.5L18.5 8 15 4.5ZM10.5 19l-1.9-.6 5-14.8 1.9.6z"/>',
  'Business Intelligence y datos': '<path d="M5 20v-8H2l10-9 10 9h-3v8H5zm4 0v-5h6v5H9z"/>',
  'Contenedores y orquestación': '<path d="M12 3 2 8.5l10 5.5 10-5.5zm0 2.27L18.73 8.5 12 11.73 5.27 8.5zM2 14l10 5.5L22 14l-1.5-.83L12 17.73l-8.5-4.56zm0-3.18 1.5.84L12 14.73l8.5-4.07 1.5-.84V8.82L12 13.5 2 8.82z"/>',
};
---

<section class="section">
  <SectionHeading
    eyebrow="Competencias técnicas"
    title="Capacidades organizadas por áreas clave del perfil"
  />

  <div class="skills-grid reveal-stagger">
    {items.map((group) => (
      <article class="skill-card">
        <div class="skill-card-header">
          {CATEGORY_ICONS[group.category] && (
            <span class="category-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" set:html={CATEGORY_ICONS[group.category]} />
            </span>
          )}
          <h3>{group.category}</h3>
        </div>
        <ul class="tag-list skill-tags">
          {group.items.map((item) => (
            <li class="skill-tag" style={TECH_COLORS[item] ? `--dot: ${TECH_COLORS[item]}` : ''}>
              {TECH_COLORS[item] && <span class="tech-dot" aria-hidden="true"></span>}
              {item}
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    gap: 1rem;
  }

  .skill-card {
    padding: 1.25rem;
    border: 1px solid var(--border-light);
    border-top: 3px solid var(--card-accent, var(--border));
    border-radius: var(--radius-lg);
    background: var(--bg-card);
    box-shadow: var(--shadow-xs);
    transition: transform 0.2s ease, box-shadow 0.25s ease;
  }

  .skill-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glass);
  }

  .skill-card:nth-child(1) { --card-accent: #059669; }
  .skill-card:nth-child(2) { --card-accent: #0284c7; }
  .skill-card:nth-child(3) { --card-accent: #6d28d9; }
  .skill-card:nth-child(4) { --card-accent: #d97706; }
  .skill-card:nth-child(5) { --card-accent: #0d9488; }
  .skill-card:nth-child(6) { --card-accent: #db2777; }
  .skill-card:nth-child(n+7) { --card-accent: var(--accent); }

  .skill-card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .category-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    flex-shrink: 0;
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--card-accent, var(--accent)) 12%, transparent);
    color: var(--card-accent, var(--accent));
  }

  .category-icon svg {
    width: 1rem;
    height: 1rem;
    fill: currentColor;
  }

  .skill-card h3 {
    margin: 0;
    font-family: 'Sora', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--heading);
    line-height: 1.3;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .skill-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.625rem;
    border-radius: 999px;
    background: var(--bg-section);
    color: var(--text-secondary);
    font-size: 0.8125rem;
    font-weight: 600;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .skill-tag:hover {
    background: var(--accent-light);
    color: var(--accent-dark);
  }

  .tech-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--dot, var(--accent));
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .skills-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.125rem;
    }

    .skill-card {
      padding: 1.5rem;
    }

    .skill-card h3 {
      font-size: 0.9375rem;
    }
  }
</style>
